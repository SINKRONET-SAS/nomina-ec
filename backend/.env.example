# Nómina-Ec - Variables de entorno
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plan_haiky
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://haiky_migration:haiky_migration_local@127.0.0.1:5432/plan_haiky?schema=public
REDIS_URL=redis://127.0.0.1:6379

# JWT
JWT_SECRET=generate-a-random-secret-of-at-least-32-characters
JWT_EXPIRES_IN=24h
EMPLOYEE_INVITE_SECRET=generate-a-different-random-secret-of-at-least-32-characters
BANK_ACCOUNT_ENCRYPTION_KEY=change-this-local-bank-key

# Bootstrap local
# Crea solo el usuario tecnico global. Las empresas y sus owners deben registrarse desde la aplicacion.
SUPERADMIN_EMAIL=info@sinkronet.com.ec
SUPERADMIN_PASSWORD=replace-with-a-local-superadmin-password

# Demo opcional: usar solo si necesitas crear un tenant owner de prueba por seed.
# OWNER_TENANT_RUC=
# OWNER_TENANT_RAZON_SOCIAL=
# OWNER_TENANT_NOMBRE_COMERCIAL=
# OWNER_EMAIL=
# OWNER_PASSWORD=

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=nomina-ec-documents

# Frontend
FRONTEND_URL=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173

# Comunicaciones transaccionales - SMTP
SMTP_ENABLED=true
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_AUTH_REQUIRED=true
SMTP_USER=notificaciones@example.com
SMTP_PASSWORD=replace-with-smtp-password
SMTP_FROM_EMAIL=notificaciones@example.com
SMTP_FROM_NAME=Nomina-Ec
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000

# Comunicaciones transaccionales - WhatsApp Business Cloud API
WHATSAPP_ENABLED=false
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_ACCESS_TOKEN=replace-with-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=replace-with-phone-number-id
WHATSAPP_TEMPLATE_LANGUAGE=es
WHATSAPP_TEMPLATE_EMPLOYEE_INVITE=nomina_ec_employee_invite
WHATSAPP_TEMPLATE_PASSWORD_RESET=nomina_ec_password_reset
WHATSAPP_TEMPLATE_EMAIL_VERIFICATION=nomina_ec_email_verification
WHATSAPP_TEMPLATE_SYSTEM_TEST=nomina_ec_system_test
