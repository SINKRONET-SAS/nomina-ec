# Nomina-Ec - Variables de entorno ejemplo
PORT=3000
NODE_ENV=development

# PostgreSQL runtime
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nomina_ec
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DATABASE_URL=postgresql://nomina_ec_app:nomina_ec_local@127.0.0.1:5432/nomina_ec?schema=public
REDIS_URL=redis://127.0.0.1:6379

# PostgreSQL admin local para scripts
PGADMIN_HOST=127.0.0.1
PGADMIN_PORT=5432
PGADMIN_DATABASE=postgres
PGADMIN_USER=postgres
PGADMIN_PASSWORD=postgres

# Seguridad
JWT_SECRET=generate-a-random-secret-of-at-least-32-characters
JWT_EXPIRES_IN=24h
EMPLOYEE_INVITE_SECRET=generate-a-different-random-secret-of-at-least-32-characters
EMPLOYEE_APP_INVITE_TTL_DAYS=7
BANK_ACCOUNT_ENCRYPTION_KEY=generate-a-local-bank-key
REQUIRE_VALIDATED_LEGAL_PARAMETERS=false

# Bootstrap local
# Crea solo el usuario tecnico global. Las empresas y sus owners se registran desde la aplicacion.
SUPERADMIN_EMAIL=info@sinkronet.com.ec
SUPERADMIN_PASSWORD=replace-with-a-local-superadmin-password
SUPERADMIN_NAMES=Superadmin
SUPERADMIN_LAST_NAMES=Nomina-Ec

# Demo opcional: dejar vacio salvo que necesites crear un tenant owner por seed.
OWNER_TENANT_RUC=
OWNER_TENANT_RAZON_SOCIAL=
OWNER_TENANT_NOMBRE_COMERCIAL=
OWNER_EMAIL=
OWNER_PASSWORD=
OWNER_NAMES=
OWNER_LAST_NAMES=

# PayPhone / facturacion comercial
# En produccion PAYPHONE_MOCK_MODE siempre se interpreta como false.
PAYPHONE_MOCK_MODE=false
PAYPHONE_API_BASE=https://pay.payphonetodoesposible.com
PAYPHONE_TOKEN=
PAYPHONE_STORE_ID=
PAYPHONE_TIMEOUT_MS=12000
COMMERCIAL_IVA_RATE=0.15
PROVIDER_INVOICE_IVA_RATE=0.15

# AWS S3 / almacenamiento documental
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=nomina-ec-documents
AWS_S3_ENDPOINT=

# Frontend y app movil
FRONTEND_URL=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173
BACKEND_PUBLIC_URL=
MOBILE_APP_ACTIVATION_URL=nominaec://employee/activate
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/api

# RLS / verificacion Render
RLS_DATABASE_URL=
RLS_TENANT_A=
RLS_TENANT_B=
RLS_EMPLOYEE_A=

# Comunicaciones transaccionales - SMTP
# Cambiar a true solo cuando existan credenciales SMTP reales.
COMMUNICATION_PROVIDER=smtp
COMMUNICATION_DEV_MODE=true
COMMUNICATION_REQUIRE_REAL_PROVIDER=false
COMMUNICATION_RETENTION_DAYS=365
COMMUNICATION_EVENT_HASH_SECRET=generate-a-different-audit-hash-secret
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_AUTH_REQUIRED=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Nomina-Ec
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000

# Comunicaciones transaccionales - WhatsApp Business Cloud API
# Cambiar a true solo cuando exista token, phone number ID y plantillas aprobadas.
WHATSAPP_ENABLED=false
WHATSAPP_API_BASE_URL=https://graph.facebook.com
WHATSAPP_GRAPH_API_VERSION=v23.0
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_LANGUAGE=es
WHATSAPP_TEMPLATE_EMPLOYEE_INVITE=nomina_ec_employee_invite
WHATSAPP_TEMPLATE_PASSWORD_RESET=nomina_ec_password_reset
WHATSAPP_TEMPLATE_EMAIL_VERIFICATION=nomina_ec_email_verification
WHATSAPP_TEMPLATE_SYSTEM_TEST=nomina_ec_system_test
