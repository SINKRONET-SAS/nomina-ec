generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  superadmin
  owner
  admin_rrhh
  supervisor
  empleado
}

enum AttendanceMarkType {
  inicio_jornada
  fin_jornada
  inicio_almuerzo
  fin_almuerzo
}

enum AttendanceNoveltyType {
  falta
  atraso
  salida_temprana
  hora_extra_50
  hora_extra_100
  bono_desempeno
}

enum ApprovalStatus {
  pendiente
  aprobado
  rechazado
}

enum PayrollStatus {
  borrador
  cerrada
  pagada
}

enum LegalDocumentType {
  contrato
  acta_finiquito
  rol_pago
  certificado
}

model Tenant {
  id                     String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruc                    String?                     @unique @db.VarChar(13)
  razonSocial            String                      @map("razon_social") @db.VarChar(200)
  nombreComercial        String?                     @map("nombre_comercial") @db.VarChar(200)
  activo                 Boolean                     @default(true)
  configuracion          Json                        @default("{}")
  ubicacionLat           Decimal?                    @map("ubicacion_lat") @db.Decimal(10, 7)
  ubicacionLng           Decimal?                    @map("ubicacion_lng") @db.Decimal(10, 7)
  radioPerimetroMetros   Int                         @default(100) @map("radio_perimetro_metros")
  createdAt              DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  usuarios               User[]
  suscripcion            Subscription?
  metodosPago            PaymentMethod[]
  transaccionesPago      PaymentTransaction[]
  empleados              Employee[]
  cargasFamiliares       EmployeeFamilyDependent[]
  nominas                Payroll[]
  marcaciones            AttendanceMark[]
  novedades              AttendanceNovelty[]
  documentos             LegalDocument[]
  parametrosLegales      LegalParameter[]
  perfilesBancarios      BankProfile[]
  homologacionesBancarias BankFieldMapping[]
  configurationCatalogs  ConfigurationCatalog[]
  legalParameterVersions LegalParameterVersion[]
  noveltyTypeConfigs     NoveltyTypeConfig[]
  organizationUnits      OrganizationUnit[]
  jobPositions           JobPosition[]
  workZones              WorkZone[]
  workShifts             WorkShift[]
  onboardingSteps        TenantOnboardingStep[]
  beneficios             EmployeeBenefit[]
  apiClients             ExternalApiClient[]
  apiIdempotencyKeys     ExternalApiIdempotencyKey[]
  employeeImportBatches  EmployeeImportBatch[]
  payrollPeriods         PayrollPeriod[]
  noveltyBatches         NoveltyBatch[]
  supportIncidents       SupportIncident[]
  communicationEvents    CommunicationEvent[]

  @@map("tenants")
}

model ExternalApiClient {
  id                 String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String                      @map("tenant_id") @db.Uuid
  name               String                      @db.VarChar(160)
  apiKeyHash         String                      @unique @map("api_key_hash") @db.VarChar(128)
  scopes             String[]                    @default([])
  active             Boolean                     @default(true)
  rateLimitPerMinute Int                         @default(60) @map("rate_limit_per_minute")
  createdAt          DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant             Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  idempotencyKeys    ExternalApiIdempotencyKey[]

  @@index([tenantId, active])
  @@map("api_clients")
}

model ExternalApiIdempotencyKey {
  id             String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId       String            @map("client_id") @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  idempotencyKey String            @map("idempotency_key") @db.VarChar(160)
  method         String            @db.VarChar(12)
  path           String
  requestHash    String            @map("request_hash") @db.VarChar(128)
  statusCode     Int               @map("status_code")
  responseBody   Json              @default("{}") @map("response_body")
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt      DateTime          @default(dbgenerated("(now() + '24:00:00'::interval)")) @map("expires_at") @db.Timestamptz(6)
  client         ExternalApiClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([clientId, idempotencyKey])
  @@index([tenantId, createdAt])
  @@map("api_idempotency_keys")
}

model User {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String?                  @map("tenant_id") @db.Uuid
  email                   String                   @db.VarChar(255)
  passwordHash            String                   @map("password_hash") @db.VarChar(255)
  rol                     UserRole
  nombres                 String                   @default("") @db.VarChar(120)
  apellidos               String                   @default("") @db.VarChar(120)
  activo                  Boolean                  @default(true)
  ultimoAcceso            DateTime?                @map("ultimo_acceso") @db.Timestamptz(6)
  emailVerificadoEn       DateTime?                @map("email_verificado_en") @db.Timestamptz(6)
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant                  Tenant?                  @relation(fields: [tenantId], references: [id])
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  transaccionesPago       PaymentTransaction[]
  communicationEvents     CommunicationEvent[]

  @@unique([tenantId, email])
  @@map("usuarios")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId String    @map("usuario_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiraEn  DateTime  @map("expira_en") @db.Timestamptz(6)
  usadoEn   DateTime? @map("usado_en") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  usuario   User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  usuarioId    String    @map("usuario_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash") @db.VarChar(255)
  expiraEn     DateTime  @map("expira_en") @db.Timestamptz(6)
  confirmadoEn DateTime? @map("confirmado_en") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  usuario      User      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@map("email_verification_tokens")
}

model CommercialPlan {
  id                    String               @id @db.VarChar(40)
  nombre                String               @db.VarChar(120)
  descripcion           String               @default("")
  precioMensualCentavos Int                  @default(0) @map("precio_mensual_centavos")
  moneda                String               @default("USD") @db.VarChar(3)
  empleadosMax          Int?                 @map("empleados_max")
  empresasMax           Int                  @default(1) @map("empresas_max")
  usuariosMax           Int                  @default(3) @map("usuarios_max")
  archivosBancarios     Boolean              @default(false) @map("archivos_bancarios")
  reportesAvanzados     Boolean              @default(false) @map("reportes_avanzados")
  soporte               String               @default("comunidad") @db.VarChar(80)
  publico               Boolean              @default(true)
  activo                Boolean              @default(true)
  orden                 Int                  @default(0)
  metadata              Json                 @default("{}")
  createdAt             DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  suscripciones         Subscription[]
  transaccionesPago     PaymentTransaction[]

  @@map("planes_comerciales")
}

model Subscription {
  id                   String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String         @unique @map("tenant_id") @db.Uuid
  planId               String         @map("plan_id") @db.VarChar(40)
  estado               String         @default("trial") @db.VarChar(40)
  inicioEn             DateTime       @default(now()) @map("inicio_en") @db.Timestamptz(6)
  venceEn              DateTime?      @map("vence_en") @db.Timestamptz(6)
  renovacionAutomatica Boolean        @default(false) @map("renovacion_automatica")
  metadata             Json           @default("{}")
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                 CommercialPlan @relation(fields: [planId], references: [id])

  @@index([planId, estado])
  @@map("suscripciones")
}

model PaymentMethod {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  proveedor           String   @default("PAYPHONE") @db.VarChar(40)
  estado              String   @default("PENDING") @db.VarChar(40)
  referenciaProveedor String?  @map("referencia_proveedor") @db.VarChar(160)
  esPrincipal         Boolean  @default(true) @map("es_principal")
  metadata            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, estado])
  @@map("metodos_pago")
}

model PaymentTransaction {
  id                    String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String          @map("tenant_id") @db.Uuid
  usuarioId             String?         @map("usuario_id") @db.Uuid
  planId                String?         @map("plan_id") @db.VarChar(40)
  proveedor             String          @default("PAYPHONE") @db.VarChar(40)
  estado                String          @default("PENDING") @db.VarChar(40)
  montoCentavos         Int             @default(0) @map("monto_centavos")
  baseGravadaCentavos   Int             @default(0) @map("base_gravada_centavos")
  baseNoGravadaCentavos Int             @default(0) @map("base_no_gravada_centavos")
  ivaCentavos           Int             @default(0) @map("iva_centavos")
  moneda                String          @default("USD") @db.VarChar(3)
  clientTransactionId   String          @unique @map("client_transaction_id") @db.VarChar(160)
  providerTransactionId String?         @map("provider_transaction_id") @db.VarChar(160)
  checkoutUrl           String?         @map("checkout_url")
  metadata              Json            @default("{}")
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario               User?           @relation(fields: [usuarioId], references: [id], onDelete: SetNull)
  plan                  CommercialPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@index([tenantId, estado])
  @@map("transacciones_pago")
}

model SupportIncident {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String?   @map("tenant_id") @db.Uuid
  title       String    @db.VarChar(180)
  description String    @default("")
  severity    String    @default("media") @db.VarChar(30)
  status      String    @default("abierta") @db.VarChar(30)
  createdBy   String?   @map("created_by") @db.Uuid
  assignedTo  String?   @map("assigned_to") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  closedAt    DateTime? @map("closed_at") @db.Timestamptz(6)
  tenant      Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([status, severity, createdAt])
  @@index([tenantId, createdAt])
  @@map("support_incidents")
}

model Employee {
  id                      String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                String                 @map("tenant_id") @db.Uuid
  cedula                  String                 @db.VarChar(10)
  nombres                 String                 @db.VarChar(120)
  apellidos               String                 @db.VarChar(120)
  fechaNacimiento         DateTime?              @map("fecha_nacimiento") @db.Date
  positionId              String?                @map("position_id") @db.Uuid
  cargo                   String                 @default("") @db.VarChar(120)
  departamento            String                 @default("") @db.VarChar(120)
  unidadOrganizativaCodigo String                @default("") @map("unidad_organizativa_codigo") @db.VarChar(80)
  jornadaCodigo           String                 @default("") @map("jornada_codigo") @db.VarChar(80)
  zonaMarcacionCodigo     String                 @default("") @map("zona_marcacion_codigo") @db.VarChar(80)
  sueldoBrutoMensual      Decimal                @map("sueldo_bruto_mensual") @db.Decimal(12, 2)
  jornadaHorasMensuales   Decimal?               @map("jornada_horas_mensuales") @db.Decimal(6, 2)
  gastosPersonalesAnuales Decimal                @default(0) @map("gastos_personales_anuales") @db.Decimal(12, 2)
  fechaIngreso            DateTime               @map("fecha_ingreso") @db.Date
  fechaSalida             DateTime?              @map("fecha_salida") @db.Date
  tipoContrato            String                 @default("indefinido") @map("tipo_contrato") @db.VarChar(60)
  cuentaBancariaCifrada   Bytes?                 @map("cuenta_bancaria_cifrada")
  importBatchId           String?                @map("import_batch_id") @db.Uuid
  banco                   String                 @default("") @db.VarChar(80)
  tipoCuenta              String                 @default("") @map("tipo_cuenta") @db.VarChar(40)
  direccionDomicilio      String                 @default("") @map("direccion_domicilio")
  provinciaCodigo         String                 @default("") @map("provincia_codigo") @db.VarChar(10)
  ciudadCodigo            String                 @default("") @map("ciudad_codigo") @db.VarChar(10)
  ciudadDomicilio         String                 @default("") @map("ciudad_domicilio") @db.VarChar(80)
  provinciaDomicilio      String                 @default("") @map("provincia_domicilio") @db.VarChar(80)
  estadoCivil             String                 @default("") @map("estado_civil") @db.VarChar(30)
  cargasFamiliares        Int                    @default(0) @map("cargas_familiares")
  formaPago               String                 @default("transferencia") @map("forma_pago") @db.VarChar(30)
  regionDecimoCuarto      String                 @default("sierra_amazonia") @map("region_decimo_cuarto") @db.VarChar(40)
  telefono                String                 @default("") @db.VarChar(40)
  emailPersonal           String                 @default("") @map("email_personal") @db.VarChar(255)
  activo                  Boolean                @default(true)
  createdAt               DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant                  Tenant                 @relation(fields: [tenantId], references: [id])
  position                JobPosition?           @relation(fields: [positionId], references: [id], onDelete: Restrict)
  marcaciones             AttendanceMark[]
  novedades               AttendanceNovelty[]
  nominas                 Payroll[]
  documentos              LegalDocument[]
  actasEquipos            EquipmentDeliveryAct[]
  beneficios              EmployeeBenefit[]
  cargasFamiliaresDetalle EmployeeFamilyDependent[]
  importBatch             EmployeeImportBatch?   @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([tenantId, activo])
  @@index([tenantId, importBatchId])
  @@index([tenantId, positionId])
  @@unique([tenantId, cedula])
  @@map("empleados")
}

model EmployeeImportBatch {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String     @map("tenant_id") @db.Uuid
  createdBy   String?    @map("created_by") @db.Uuid
  sourceName  String     @default("carga_manual") @map("source_name") @db.VarChar(180)
  status      String     @default("preview") @db.VarChar(30)
  totalRows   Int        @default(0) @map("total_rows")
  validRows   Int        @default(0) @map("valid_rows")
  errorRows   Int        @default(0) @map("error_rows")
  summary     Json       @default("{}")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt DateTime?  @map("completed_at") @db.Timestamptz(6)
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  empleados   Employee[]

  @@index([tenantId, createdAt])
  @@map("employee_import_batches")
}

model EmployeeBenefit {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  empleadoId     String    @map("empleado_id") @db.Uuid
  tipo           String    @db.VarChar(40)
  descripcion    String    @default("")
  montoTotal     Decimal   @default(0) @map("monto_total") @db.Decimal(12, 2)
  saldoPendiente Decimal   @default(0) @map("saldo_pendiente") @db.Decimal(12, 2)
  cuotaMensual   Decimal   @default(0) @map("cuota_mensual") @db.Decimal(12, 2)
  anioInicio     Int       @map("anio_inicio")
  mesInicio      Int       @map("mes_inicio")
  estado         String    @default("pendiente") @db.VarChar(40)
  aprobadoPor    String?   @map("aprobado_por") @db.Uuid
  aprobadoEn     DateTime? @map("aprobado_en") @db.Timestamptz(6)
  metadata       Json      @default("{}")
  createdBy      String?   @map("created_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  empleado       Employee  @relation(fields: [empleadoId], references: [id], onDelete: Cascade)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, estado])
  @@index([empleadoId, anioInicio, mesInicio])
  @@map("beneficios_empleados")
}

model EmployeeFamilyDependent {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId               String   @map("tenant_id") @db.Uuid
  employeeId             String   @map("employee_id") @db.Uuid
  nombres                String   @db.VarChar(120)
  apellidos              String   @default("") @db.VarChar(120)
  identificacion         String   @default("") @db.VarChar(20)
  parentesco             String   @db.VarChar(40)
  fechaNacimiento        DateTime? @map("fecha_nacimiento") @db.Date
  discapacidad           Boolean  @default(false)
  porcentajeDiscapacidad Decimal? @map("porcentaje_discapacidad") @db.Decimal(5, 2)
  documentoUrl           String   @default("") @map("documento_url")
  metadata               Json     @default("{}")
  activo                 Boolean  @default(true)
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee               Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("employee_family_dependents")
}

model AttendanceMark {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  empleadoId      String             @map("empleado_id") @db.Uuid
  tenantId        String             @map("tenant_id") @db.Uuid
  periodId        String?            @map("period_id") @db.Uuid
  operationalDate DateTime?          @map("operational_date") @db.Date
  workZoneId      String?            @map("work_zone_id") @db.Uuid
  organizationUnitId String?         @map("organization_unit_id") @db.Uuid
  workShiftId     String?            @map("work_shift_id") @db.Uuid
  tipoMarcacion   AttendanceMarkType @map("tipo_marcacion")
  timestamp       DateTime           @db.Timestamptz(6)
  latitud         Decimal?           @db.Decimal(10, 7)
  longitud        Decimal?           @db.Decimal(10, 7)
  accuracyMeters  Decimal?           @map("accuracy_meters") @db.Decimal(10, 2)
  dentroPerimetro Boolean            @default(true) @map("dentro_perimetro")
  distanciaMetros Decimal            @default(0) @map("distancia_metros") @db.Decimal(10, 2)
  fotoUrl         String?            @map("foto_url")
  ipAddress       String?            @map("ip_address") @db.VarChar(80)
  source          String             @default("web") @db.VarChar(40)
  auditCorrelationId String?         @map("audit_correlation_id") @db.VarChar(120)
  metadata        Json               @default("{}")
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  empleado        Employee           @relation(fields: [empleadoId], references: [id])
  tenant          Tenant             @relation(fields: [tenantId], references: [id])

  @@index([tenantId, empleadoId, timestamp])
  @@index([tenantId, empleadoId, operationalDate])
  @@index([tenantId, periodId, empleadoId])
  @@index([tenantId, workZoneId, operationalDate])
  @@map("marcaciones")
}

model EmployeeAppInvite {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  empleadoId           String    @map("empleado_id") @db.Uuid
  email                String    @default("") @db.VarChar(255)
  inviteCodeHash       String    @map("invite_code_hash") @db.VarChar(128)
  status               String    @default("PENDING_INVITE") @db.VarChar(30)
  expiresAt            DateTime  @map("expires_at") @db.Timestamptz(6)
  invitedByUserId      String?   @map("invited_by_user_id") @db.Uuid
  inviteResendCount    Int       @default(0) @map("invite_resend_count")
  acceptedAt           DateTime? @map("accepted_at") @db.Timestamptz(6)
  acceptedByUserId     String?   @map("accepted_by_user_id") @db.Uuid
  revokedAt            DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedByUserId      String?   @map("revoked_by_user_id") @db.Uuid
  privacyNoticeVersion String    @default("") @map("privacy_notice_version") @db.VarChar(40)
  metadata             Json      @default("{}")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tenantId, empleadoId, status])
  @@index([tenantId, status, expiresAt])
  @@map("employee_app_invites")
}

model EmployeeAppLink {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  empleadoId           String    @map("empleado_id") @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  status               String    @default("ACTIVE") @db.VarChar(30)
  activatedAt          DateTime  @default(now()) @map("activated_at") @db.Timestamptz(6)
