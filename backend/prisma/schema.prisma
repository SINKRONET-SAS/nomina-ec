  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organizationUnits OrganizationUnit[]

  @@index([tenantId, status])
  @@map("work_zones")
}

model WorkShift {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  code             String    @db.VarChar(80)
  name             String    @db.VarChar(160)
  shiftType        String    @default("ordinaria") @map("shift_type") @db.VarChar(60)
  weeklyHours      Decimal   @default(40) @map("weekly_hours") @db.Decimal(6, 2)
  startTime        String    @default("08:00") @map("start_time") @db.VarChar(5)
  endTime          String    @default("17:00") @map("end_time") @db.VarChar(5)
  breakMinutes     Int       @default(60) @map("break_minutes")
  toleranceMinutes Int       @default(10) @map("tolerance_minutes")
  overtimeRules    Json      @default("{}") @map("overtime_rules")
  calendarRules    Json      @default("{}") @map("calendar_rules")
  status           String    @default("activo") @db.VarChar(30)
  validFrom        DateTime  @default(now()) @map("valid_from") @db.Date
  validTo          DateTime? @map("valid_to") @db.Date
  createdBy        String?   @map("created_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, shiftType])
  @@map("work_shifts")
}

model TenantOnboardingStep {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  stepCode    String    @map("step_code") @db.VarChar(80)
  status      String    @default("pendiente") @db.VarChar(30)
  completedBy String?   @map("completed_by") @db.Uuid
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  evidence    Json      @default("{}")
  notes       String    @default("")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, stepCode])
  @@index([tenantId, status])
  @@map("tenant_onboarding_steps")
}
