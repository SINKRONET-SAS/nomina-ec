{
  "name": "sknomina-system",
  "version": "1.0.0",
  "private": true,
  "description": "SKNOMINA como un solo sistema: backend, PWA web y app movil gobernados desde la raiz.",
  "overrides": {
    "fast-uri": "3.1.4",
    "uuid": "11.1.1",
    "exceljs": {
      "uuid": "11.1.1"
    },
    "xcode": {
      "uuid": "11.1.1"
    }
  },
  "workspaces": [
    "backend",
    "frontend-web",
    "app-movil"
  ],
  "scripts": {
    "contracts": "node scripts/verify-system-contracts.mjs",
    "prisma:validate": "npm --workspace=backend run prisma:validate",
    "test:backend": "npm --workspace=backend test",
    "build:web": "npm --workspace=frontend-web run build",
    "check:mobile": "npm --workspace=app-movil run check:stores",
    "audit:integral": "node scripts/haiky-integral-diagnostic.mjs",
    "haiky:solution": "node scripts/haiky-integral-solution.mjs",
    "audit:integral:v2": "node scripts/haiky-integral-v2-diagnostic.mjs",
    "haiky:solution:v2": "node scripts/haiky-integral-v2-solution.mjs",
    "audit:reportes:2026": "node scripts/haiky-reportes-disponibilidad-2026-diagnostic.mjs",
    "tpc26:storage:inventory": "node scripts/tpc26-storage-inventory.mjs",
    "tpc26:storage:dry-run": "node scripts/tpc26-storage-cleanup.mjs",
    "haiky:reportes:2026": "node scripts/haiky-reportes-disponibilidad-2026-solution.mjs",
    "audit:roles:2026": "node scripts/haiky-payroll-correction-2026-diagnostic.mjs",
    "haiky:roles:2026": "node scripts/haiky-payroll-correction-2026-solution.mjs",
    "audit:brand-assets": "node scripts/haiky-brand-assets-diagnostic.mjs",
    "audit:brand-visual": "node scripts/haiky-visual-regression-capture.mjs",
    "brand:assets:solution": "node scripts/haiky-brand-assets-solution.mjs && node scripts/haiky-brand-assets-diagnostic.mjs",
    "brand:assets:auditlock": "node scripts/haiky-brand-assets-auditlock.mjs",
    "validate": "npm run contracts && npm run prisma:validate && npm run test:backend && npm run build:web"
  }
}
