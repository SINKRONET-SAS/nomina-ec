{
  "expo": {
    "name": "SKNOMINA",
    "slug": "nomina-ec",
    "description": "SKNOMINA permite registrar asistencia, rutas de campo, permisos y autoservicio laboral para empresas en Ecuador.",
    "scheme": "sknomina",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "ec.com.sknomina.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SKNOMINA usa ubicación aproximada durante la marcación de asistencia."
      }
    },
    "android": {
      "package": "ec.com.sknomina.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f766e"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "expo-status-bar"
    ],
    "extra": {
      "apiBaseUrl": "https://api.sknomina.com/api",
      "privacyUrl": "https://sknomina.com/privacidad",
      "androidPrivacyPolicyUrl": "https://sknomina.com/privacidad",
      "termsUrl": "https://sknomina.com/terminos",
      "supportUrl": "https://sknomina.com/soporte",
      "accountDeletionUrl": "https://sknomina.com/eliminar-cuenta",
      "eas": {
        "projectId": "0f419acd-43c8-46d2-a962-2bce1112b194"
      }
    },
    "owner": "sinkroniq_mobile"
  }
}
