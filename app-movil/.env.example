# Nomina-Ec Expo - Variables locales

# APK preview/produccion usa este valor por defecto si no existe .env:
EXPO_PUBLIC_API_URL=https://api.sknomina.com/api

# Desarrollo local opcional:
# Android emulator: EXPO_PUBLIC_API_URL=http://10.0.2.2:3000/api
# Expo Go en telefono fisico: EXPO_PUBLIC_API_URL=http://IP_LOCAL_DE_TU_PC:3000/api
